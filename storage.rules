rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public trip gallery images
    match /trip-photos/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Passport/ID uploads — Admin SDK only (signed upload via API route)
    match /passport-documents/{allPaths=**} {
      allow read, write: if false;
    }

    // Bank transfer / PromptPay slips — Admin SDK only
    match /payment-slips/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
