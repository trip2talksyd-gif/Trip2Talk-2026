rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public catalog reads for real-time UI (writes always via Admin SDK API routes)
    match /tripTemplates/{tripCode} {
      allow read: if true;
      allow write: if false;
    }

    match /tripDepartures/{departureId} {
      allow read: if true;
      allow write: if false;
    }

    // All other collections — no client access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
